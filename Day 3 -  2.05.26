
// Problem 1 -- 
//print 1 to 10 using a for looop

#include <iostream>
using namespace std;

int main () {
    for(int i = 1; i <= 10; i++){
        cout <<i << " ";
    }
    return 0;
}


// Problem 2 -- 
//print 1 to 10 using a for looop

#include <iostream>
using namespace std;

int main () {
    for(int i = 10; i>=1; i--){
        cout <<i << " ";
    }
    return 0;
}
